---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div
  class="rounded-lg border border-line bg-surface p-5 transition-colors duration-200 hover:border-line-strong"
>
  <div class="flex items-baseline justify-between gap-4">
    <h2 class="font-serif text-lg text-ink">{project.name}</h2>
    <span class="font-sans text-xs uppercase tracking-wider text-ink-faint">
      {project.kind}
    </span>
  </div>
  <p class="mt-2 text-sm leading-relaxed text-ink-muted">
    {project.description}
  </p>
</div>
