---
// Forward-looking: Field Notes don't use video yet, but the architecture is
// ready. Self-hosted clip (`embed={false}`, native <video>) or an embed URL
// (`embed`, sandboxed <iframe> for YouTube/Vimeo). `title` is required for a11y.
interface Props {
  src: string;
  title: string;
  poster?: string;
  caption?: string;
  embed?: boolean;
  variant?: 'text' | 'wide' | 'full';
}

const {
  src,
  title,
  poster,
  caption,
  embed = false,
  variant = 'wide',
} = Astro.props;

const variantClass =
  variant === 'wide' ? 'fig-wide' : variant === 'full' ? 'fig-full' : '';
---

<figure class={variantClass}>
  <div class="aspect-video overflow-hidden rounded-lg border border-line bg-surface">
    {
      embed ? (
        <iframe
          src={src}
          title={title}
          class="h-full w-full"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        />
      ) : (
        <video
          src={src}
          poster={poster}
          controls
          preload="metadata"
          class="h-full w-full"
          aria-label={title}
        />
      )
    }
  </div>
  {
    caption && (
      <figcaption class="mt-3 font-sans text-sm leading-relaxed text-ink-faint">
        {caption}
      </figcaption>
    )
  }
</figure>
