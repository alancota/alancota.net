---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Not Found"
  description="That page doesn’t exist — but the field notes do."
>
  <div class="mx-auto w-full max-w-2xl">
    <p class="font-sans text-xs uppercase tracking-[0.18em] text-accent">404</p>
    <h1 class="mt-5 font-serif text-3xl leading-tight tracking-tight text-ink sm:text-4xl">
      This door leads nowhere.
    </h1>
    <p class="mt-6 font-serif text-lg leading-relaxed text-ink-muted">
      The page you were looking for isn’t here. Try the <a
        href="/field-notes"
        class="text-ink underline decoration-line-strong underline-offset-4 transition-colors hover:text-accent hover:decoration-accent"
        >field notes</a
      >, or head back <a
        href="/"
        class="text-ink underline decoration-line-strong underline-offset-4 transition-colors hover:text-accent hover:decoration-accent"
        >home</a
      >.
    </p>
  </div>
</BaseLayout>
