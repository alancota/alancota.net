---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Figure, Gallery, Video } from '../../components/media';

// Drafts are excluded from production builds entirely — not public, not
// linked, not generated (static sites have no access control).
export async function getStaticPaths() {
  const notes = await getCollection('field-notes', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );
  return notes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const publishedOn = entry.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC', // publishDate is a UTC midnight; render the calendar date as-authored
});

// Rough reading-time estimate from the raw body (~220 wpm).
const words = entry.body?.trim().split(/\s+/).length ?? 0;
const minutes = Math.max(1, Math.round(words / 220));
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="mx-auto w-full max-w-4xl">
    <header class="mx-auto w-full max-w-[42rem]">
      <p class="font-sans text-xs uppercase tracking-[0.18em] text-accent">
        Field Note
      </p>
      <h1 class="mt-5 font-serif text-3xl font-semibold leading-[1.15] tracking-tight text-ink sm:text-[2.75rem]">
        {entry.data.title}
      </h1>
      <p class="mt-6 font-serif text-xl leading-relaxed text-ink-muted">
        {entry.data.description}
      </p>
      <div class="mt-6 flex items-center gap-2 font-sans text-sm text-ink-faint">
        <time datetime={entry.data.publishDate.toISOString()}>{publishedOn}</time>
        <span aria-hidden="true">·</span>
        <span>{minutes} min read</span>
      </div>
    </header>

    <hr class="mx-auto mt-10 w-full max-w-[42rem] border-line" />

    <div class="prose mt-10">
      <Content components={{ Figure, Gallery, Video }} />
    </div>

    <footer class="mx-auto mt-16 w-full max-w-[42rem] border-t border-line pt-8">
      <a
        href="/field-notes"
        class="group inline-flex items-center gap-2 font-sans text-sm text-ink-muted transition-colors hover:text-accent"
      >
        <span class="transition-transform duration-200 group-hover:-translate-x-1">
          ←
        </span>
        All field notes
      </a>
    </footer>
  </article>
</BaseLayout>
