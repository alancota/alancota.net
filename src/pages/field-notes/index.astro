---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Drafts are visible in dev, hidden in production listings.
const fieldNotes = (
  await getCollection('field-notes', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  )
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Field Notes" description="Short technical articles and observations.">
  <h1 class="text-2xl font-semibold text-neutral-100">Field Notes</h1>

  {
    fieldNotes.length === 0 ? (
      <p class="mt-4 text-neutral-400">No field notes published yet.</p>
    ) : (
      <ul class="mt-6 space-y-4">
        {fieldNotes.map((entry) => (
          <li>
            <span class="font-medium text-neutral-100">{entry.data.title}</span>
            <p class="text-sm text-neutral-400">{entry.data.description}</p>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
