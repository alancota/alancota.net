---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';

// Detail pages are intentionally not built yet; these cards describe the work
// at a high level and invite future expansion (see src/data/projects.ts).
---

<BaseLayout
  title="Projects"
  description="Concepts, labs, and demo environments — evidence of how the work holds up in practice."
>
  <div class="mx-auto w-full max-w-3xl">
    <header class="max-w-2xl">
      <h1 class="font-serif text-3xl tracking-tight text-ink sm:text-4xl">
        Projects
      </h1>
      <p class="mt-4 font-serif text-lg leading-relaxed text-ink-muted">
        Concepts, labs, and demo environments — evidence of how the thinking
        holds up in practice. Detailed write-ups are on the way.
      </p>
    </header>

    <div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</BaseLayout>
