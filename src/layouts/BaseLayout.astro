---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const year = new Date().getFullYear();
// Avoid "Alan Cota · Alan Cota" on the home page.
const fullTitle = title === 'Alan Cota' ? title : `${title} · Alan Cota`;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : undefined;

// Active-nav detection. Normalize trailing slashes so "/projects" and
// "/projects/" both match, and treat any /field-notes/* path as active.
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const navLinks = [
  { href: '/field-notes', label: 'Field Notes' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="author" content="Alan Cota" />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph / social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Alan Cota" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
  </head>
  <body class="flex min-h-screen flex-col bg-base text-ink">
    <a
      href="#main"
      class="sr-only rounded-md bg-surface px-4 py-2 text-sm text-ink focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50"
    >
      Skip to content
    </a>

    <header class="border-b border-line">
      <nav
        class="mx-auto flex w-full max-w-3xl flex-wrap items-center justify-between gap-x-8 gap-y-3 px-5 py-5 sm:px-6"
        aria-label="Primary"
      >
        <a
          href="/"
          class="font-serif text-lg tracking-tight text-ink transition-colors hover:text-accent"
          aria-current={path === '/' ? 'page' : undefined}
        >
          Alan Cota
        </a>
        <ul class="flex flex-wrap items-center gap-x-6 gap-y-1 text-sm">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive(link.href) ? 'page' : undefined}
                  class:list={[
                    'transition-colors hover:text-ink',
                    isActive(link.href)
                      ? 'text-ink'
                      : 'text-ink-muted',
                  ]}
                >
                  {link.label}
                  <span
                    class:list={[
                      'mt-1 block h-px origin-left transition-transform',
                      isActive(link.href)
                        ? 'scale-x-100 bg-accent'
                        : 'scale-x-0 bg-transparent',
                    ]}
                    aria-hidden="true"
                  />
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main id="main" class="w-full flex-1 px-5 py-16 sm:px-6 sm:py-20">
      <slot />
    </main>

    <footer class="border-t border-line">
      <div
        class="mx-auto flex w-full max-w-3xl flex-col gap-2 px-5 py-8 text-sm text-ink-faint sm:flex-row sm:items-center sm:justify-between sm:px-6"
      >
        <span>© {year} Alan Cota · Field notes from customer-facing engineering</span>
        <a
          href="https://github.com/alancota"
          class="text-ink-muted transition-colors hover:text-accent"
          rel="me"
        >
          GitHub
        </a>
      </div>
    </footer>
  </body>
</html>
